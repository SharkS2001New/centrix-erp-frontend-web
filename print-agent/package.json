{
  "name": "centrix-print-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Local silent print service for Centrix ERP tills",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "build:msi": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-msi.ps1"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "playwright": "^1.51.0"
  }
}
